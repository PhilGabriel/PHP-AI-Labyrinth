# robots.txt example for a site using PHP AI Labyrinth
#
# The labyrinth path (/trap/ or /research/articles.php in this example)
# must NOT be listed under Disallow — otherwise bots that respect robots.txt
# will skip it and you lose the trap effect.
#
# Only list paths you genuinely want crawlers to skip.

User-agent: *
Disallow: /admin/
Disallow: /api/
Disallow: /private/
# /trap/ or /research/articles.php are intentionally absent

# Optional: explicitly allow the trap path to make it extra tempting
# Allow: /trap/

Sitemap: https://example.com/sitemap.xml
